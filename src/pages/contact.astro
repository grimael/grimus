---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
import { withBase } from '../lib/paths';

const subject = encodeURIComponent('Projet data depuis votre portfolio');
const body = encodeURIComponent('Bonjour,\n\nJe souhaite discuter avec vous d’un projet data.\n\nContexte :\nObjectif :\nDélai :\n');

const contacts = [
  {
    label: 'Email',
    sublabel: profile.email,
    href: `mailto:${profile.email}?subject=${subject}&body=${body}`,
    icon: 'https://cdn.simpleicons.org/gmail/EA4335',
    external: false,
  },
  {
    label: 'LinkedIn',
    sublabel: 'Voir mon profil',
    href: profile.linkedin,
    icon: 'https://cdn.simpleicons.org/linkedin/0A66C2',
    external: true,
  },
  {
    label: 'GitHub',
    sublabel: 'grimael',
    href: profile.github,
    icon: 'https://cdn.simpleicons.org/github/181717',
    external: true,
  },
];
---

<BaseLayout
  title="Contact"
  description="Contact pour un projet data, tableau de bord, visualisation, statistique ou analyse économétrique."
>
  <section class="page-hero page-hero-media contact-hero section-accent section-accent-coral">
    <div>
      <p class="eyebrow">Contact</p>
      <h1>Parlons du problème, du livrable et de l'effet que vous voulez produire.</h1>
    </div>
    <figure class="section-visual">
      <img
        src={withBase('/assets/Images/optimized/grimus2.webp')}
        alt="Visuel de la page contact"
        loading="lazy"
        decoding="async"
        width="900"
        height="675"
      />
      <figcaption>Discussion projet</figcaption>
    </figure>
  </section>

  <section class="faq-grid section-accent section-accent-gold" data-reveal>
    <article>
      <h3>Quels projets ?</h3>
      <p>Analyse statistique, tableaux de bord, cartographie, data storytelling, rapports et supports de présentation.</p>
    </article>
    <article>
      <h3>Quels livrables ?</h3>
      <p>Tableau de bord, rapport analytique, notebook, présentation, visualisation ou aide à la décision.</p>
    </article>
    <article>
      <h3>Quelle sécurité ?</h3>
      <p>Pas de token GitHub côté client, pas de base de données exposée, pas de collecte invisible via formulaire.</p>
    </article>
  </section>

  <section class="section-accent section-accent-green" data-reveal>
    <p class="eyebrow">Canaux disponibles</p>
    <h2>Choisissez votre moyen de contact préféré.</h2>
    <div class="social-grid">
      {contacts.map((c) => (
        <a
          class="social-card"
          href={c.href}
          target={c.external ? '_blank' : undefined}
          rel={c.external ? 'noopener noreferrer' : undefined}
          aria-label={c.label}
          data-logo={c.label.slice(0, 2).toUpperCase()}
        >
          <img src={c.icon} alt={c.label} width="48" height="48" loading="lazy" decoding="async" referrerpolicy="no-referrer" fetchpriority="low" />
          <strong>{c.label}</strong>
          <small>{c.sublabel}</small>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

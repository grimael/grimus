---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { profile, skillLogos } from '../data/profile';
import { withBase } from '../lib/paths';

const skillGroups = Array.from(new Set(skillLogos.map((skill) => skill.group)));
---

<BaseLayout
  title="Profil"
  description="Profil de statisticien et data analyst : compétences, approche, outils et philosophie de travail."
>
  <section class="page-hero page-hero-media about-hero section-accent section-accent-blue">
    <div>
      <p class="eyebrow">Profil</p>
      <h1>Un profil data qui relie science statistique, analyse métier et développement web.</h1>
      <p>{profile.headline}</p>
    </div>
    <figure class="section-visual">
      <img
        src={withBase('/assets/Images/optimized/Grimus.webp')}
        alt="Visuel de la page profil"
        loading="lazy"
        decoding="async"
        width="900"
        height="675"
      />
      <figcaption>Profil data</figcaption>
    </figure>
  </section>

  <section class="about-grid section-accent section-accent-green">
    <div class="about-copy">
      <SectionHeading
        eyebrow="Approche"
        title="Comprendre avant de visualiser. Prouver avant de convaincre."
      />
      <p>
        Diplômé de l'ENSEA d'Abidjan, je combine les méthodes quantitatives, l'économétrie, la BI et l'ingénierie des données
        pour concevoir des solutions data complètes : collecte, pipelines ETL, entrepôt de données, tableaux de bord et analyses.
      </p>
      <p>
        Mes expériences couvrent l'assurance, le service public, la formation professionnelle et la recherche appliquée,
        avec un fil conducteur : rendre la donnée fiable, lisible et utile à la décision.
      </p>
    </div>
    <figure class="section-visual">
      <img
        src={withBase('/assets/Images/optimized/grimus2.webp')}
        alt="Visuel de la section approche"
        loading="lazy"
        decoding="async"
        width="900"
        height="675"
      />
      <figcaption>Approche analytique</figcaption>
    </figure>
  </section>

  <section class="section-accent section-accent-gold">
    <SectionHeading
      eyebrow="Compétences"
      title="Une boîte à outils complète pour passer du dataset au livrable."
    />
    <div class="skill-categories">
      {skillGroups.map((group) => (
        <section class="skill-category">
          <h3>{group}</h3>
          <div class="skills-matrix skill-logo-grid">
            {skillLogos.filter((skill) => skill.group === group).map((skill) => (
              <article data-logo={skill.initials ?? skill.name.slice(0, 2).toUpperCase()}>
                {skill.icon ? (
                  <img src={skill.icon} alt={skill.name} loading="lazy" decoding="async" referrerpolicy="no-referrer" width="38" height="38" fetchpriority="low" />
                ) : (
                  <span class="skill-initials">{skill.initials}</span>
                )}
                <strong>{skill.name}</strong>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="section-accent section-accent-violet" data-reveal>
    <SectionHeading
      eyebrow="Experience"
      title="Des missions data concrètes, connectées aux enjeux métiers."
    />
    <div class="timeline">

      <div class="timeline-item is-current">
        <div class="timeline-marker">
          <span class="timeline-dot"></span>
          <span class="timeline-line"></span>
        </div>
        <div class="timeline-content">
          <div class="timeline-header">
            <span class="timeline-date">Janv. 2026 — Présent</span>
            <span class="timeline-badge current">En poste</span>
          </div>
          <h3 class="timeline-role">Support Data & Business Intelligence</h3>
          <p class="timeline-org">SanlamAllianz Participations</p>
          <p class="timeline-desc">
            Analyse de données financières clients, conception de tableaux de bord Power BI
            et mise en place de pipelines ETL via Apache Hop pour automatiser le reporting mensuel.
          </p>
          <div class="timeline-stack">
            <span>Power BI</span>
            <span>Apache Hop</span>
            <span>ETL</span>
            <span>SQL</span>
            <span>Finance</span>
          </div>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker">
          <span class="timeline-dot"></span>
          <span class="timeline-line"></span>
        </div>
        <div class="timeline-content">
          <div class="timeline-header">
            <span class="timeline-date">Oct. 2025 — Janv. 2026</span>
          </div>
          <h3 class="timeline-role">Statisticien — Data Analyst</h3>
          <p class="timeline-org">Observatoire du Service Public</p>
          <p class="timeline-desc">
            Analyse multi-sources et production de rapports analytiques avec recommandations
            stratégiques. Suivi et modélisation d'indicateurs de performance du service public.
          </p>
          <div class="timeline-stack">
            <span>Python</span>
            <span>R</span>
            <span>KPI</span>
            <span>Reporting</span>
            <span>Service public</span>
          </div>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker">
          <span class="timeline-dot"></span>
        </div>
        <div class="timeline-content">
          <div class="timeline-header">
            <span class="timeline-date">Mai 2025 — Sept. 2025</span>
          </div>
          <h3 class="timeline-role">Statisticien — Data Analyst</h3>
          <p class="timeline-org">Ministere de l'Enseignement Technique</p>
          <p class="timeline-desc">
            Architecture ETL et entrepôt de données national, modélisation de KPIs nationaux
            et mise en place d'un reporting automatisé sous Apache Superset.
          </p>
          <div class="timeline-stack">
            <span>Apache Superset</span>
            <span>Data Warehouse</span>
            <span>ETL</span>
            <span>SQL</span>
            <span>Education</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="principles-grid">
    <article>
      <span>Explorer</span>
      <p>Identifier les tendances, anomalies et questions importantes avant de construire le livrable.</p>
    </article>
    <article>
      <span>Modeliser</span>
      <p>Choisir des methodes statistiques adaptees, lisibles et defendables.</p>
    </article>
    <article>
      <span>Raconter</span>
      <p>Transformer les résultats en supports clairs pour des publics techniques et non techniques.</p>
    </article>
  </section>
</BaseLayout>

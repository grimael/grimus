---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredProjects, projects } from '../data/projects';
import { profile, skillLogos } from '../data/profile';
import { withBase } from '../lib/paths';

const skillGroups = Array.from(new Set(skillLogos.map((skill) => skill.group)));
---

<BaseLayout
  title="Accueil"
  description="Portfolio data : analyste data, statisticien, développeur web et concepteur de récits visuels basé à Abidjan."
>
  <section class="hero section-accent section-accent-blue" data-reveal>
    <div class="hero-content">
      <h1>Statisticien | Data Scientist & Data Analyst</h1>
      <p class="hero-lead">{profile.bio}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={withBase('/projects/')}>Mes projets</a>
        <a class="btn btn-ghost" href={profile.cv} target="_blank" rel="noopener noreferrer">CV</a>
      </div>
      <div class="logo-strip" aria-label="Competences principales">
        {skillLogos.filter(s => s.icon).slice(0, 8).map((skill) => (
          <span title={skill.name} data-logo={skill.initials ?? skill.name.slice(0, 2).toUpperCase()}>
            <img src={skill.icon} alt={skill.name} loading="lazy" decoding="async" referrerpolicy="no-referrer" width="28" height="28" fetchpriority="low" />
          </span>
        ))}
      </div>
    </div>
    <aside class="hero-showcase" aria-label="Aperçu visuel du portfolio">
      <div class="showcase-main">
        <img
          src={withBase('/assets/Images/optimized/Grimus.webp')}
          alt="Visuel de présentation"
          width="900"
          height="1125"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </aside>
  </section>

  <section class="split-section section-accent section-accent-green" data-reveal>
    <div>
      <SectionHeading
        eyebrow="Signature"
        title="Un profil hybride : statistique, produit data et web."
        text="Je ne produis pas seulement des graphiques. Je construit  des supports qui inspirent confiance et qui peuvent vivre dans un vrai environnement digital."
      />
    </div>
    <div class="capability-grid">
      <article>
        <span>01</span>
        <h3>Statistique appliquée</h3>
        <p>Modèles, tests, économétrie et interprétation rigoureuse pour passer du signal brut à la décision.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Tableaux de bord premium</h3>
        <p>Power BI, R Shiny et interfaces analytiques pour rendre les indicateurs lisibles et actionnables.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Web & storytelling</h3>
        <p>Pages, supports et expériences web qui donnent une vraie présence aux résultats.</p>
      </article>
    </div>
  </section>

  <section class="work-preview section-accent section-accent-coral" data-reveal>
    <SectionHeading
      eyebrow="Aperçu"
      title="Des livrables concrets, visuels et présentables."
      text="Tableaux de bord interactifs, cartographie, applications statistiques — des résultats qui parlent d'eux-mêmes."
    />
    <div class="preview-grid">
      <figure class="preview-card preview-main">
        <img src={withBase('/assets/Images/optimized/power.webp')} alt="Tableau de bord Power BI" loading="lazy" decoding="async" width="900" height="560" />
        <figcaption>
          <strong>Tableau de bord Power BI</strong>
          <span>Reporting financier & KPIs</span>
        </figcaption>
      </figure>
      <figure class="preview-card">
        <img src={withBase('/assets/Images/optimized/shiny.webp')} alt="Application R Shiny" loading="lazy" decoding="async" width="900" height="560" />
        <figcaption>
          <strong>Application R Shiny</strong>
          <span>Analyse statistique interactive</span>
        </figcaption>
      </figure>
      <figure class="preview-card">
        <img src={withBase('/assets/Images/optimized/qgis.webp')} alt="Cartographie QGIS" loading="lazy" decoding="async" width="900" height="560" />
        <figcaption>
          <strong>Cartographie QGIS</strong>
          <span>Visualisation spatiale</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section-accent section-accent-violet" data-reveal>
    <SectionHeading
      eyebrow="Sélection"
      title="Des projets présentés avec image, impact et accès direct."
      text="Chaque carte présente le contexte, l'impact, les technologies utilisées et un accès direct au livrable."
    />
    <div class="featured-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="center-action">
      <a class="btn btn-ghost" href={withBase('/projects/')}>Voir les {projects.length} projets</a>
    </div>
  </section>

  <section class="skills-band section-accent section-accent-gold" data-reveal>
    <p class="eyebrow">Outils, langages et technologies</p>
    <div class="skill-categories">
      {skillGroups.map((group) => (
        <section class="skill-category">
          <h3>{group}</h3>
          <div class="skill-logo-grid">
            {skillLogos.filter((skill) => skill.group === group).map((skill) => (
              <article data-logo={skill.initials ?? skill.name.slice(0, 2).toUpperCase()}>
                {skill.icon ? (
                  <img src={skill.icon} alt={skill.name} loading="lazy" decoding="async" referrerpolicy="no-referrer" width="38" height="38" fetchpriority="low" />
                ) : (
                  <span class="skill-initials">{skill.initials}</span>
                )}
                <strong>{skill.name}</strong>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="cta-section" data-reveal>
    <div>
      <p class="eyebrow">Collaboration</p>
      <h2>Vous avez un projet data ? Transformons-le en livrable concret.</h2>
      <p>Analyse, tableau de bord, rapport ou application web — je prends en charge le projet de bout en bout, de la donnée au résultat.</p>
    </div>
    <a class="btn btn-primary" href={withBase('/contact/')}>Contact</a>
  </section>
</BaseLayout>

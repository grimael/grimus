---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { projects } from '../data/projects';
import { withBase } from '../lib/paths';

const categories = ['Tous', ...Array.from(new Set(projects.map((project) => project.category)))];
---

<BaseLayout
  title="Projets"
  description="Projets data, tableaux de bord, économétrie, cartographie et visualisation avec liens vers livrables et dépôts GitHub."
>
  <section class="page-hero page-hero-media section-accent section-accent-violet">
    <div>
      <p class="eyebrow">Portfolio de projets</p>
      <h1>Des projets data présentés comme des produits finis.</h1>
    </div>
    <figure class="section-visual">
      <img
        src={withBase('/assets/Images/optimized/Grimus.webp')}
        alt="Visuel de la page projets"
        loading="lazy"
        decoding="async"
        width="900"
        height="675"
      />
      <figcaption>Livrables data</figcaption>
    </figure>
  </section>

  <section class="filter-shell" aria-label="Categories de projets">
    {categories.map((category) => (
      <button class={category === 'Tous' ? 'is-active' : ''} type="button" data-filter={category}>
        {category}
      </button>
    ))}
  </section>

  <section id="all" class="section-accent section-accent-blue">
    <SectionHeading
      eyebrow="Tous les projets"
      title={`${projects.length} livrables sélectionnés`}
      text="Le design privilégie la lecture rapide : image, contexte, impact, technologies, livrable et dépôt."
    />
    <div class="projects-list">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p class="empty-state" data-empty-state>Aucun projet dans cette catégorie pour le moment.</p>
  </section>
</BaseLayout>
